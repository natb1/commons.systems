{
  "permissions": {
    "allow": [
      "Skill(pr-workflow)",
      "Skill(pr-workflow-ci-monitor)",
      "Skill(pr-workflow-progress-report)",
      "Skill(pr-workflow-termination-summary)",
      "Skill(ready)",
      "Skill(ref-code-quality)",
      "Skill(ref-create-pr)",
      "Skill(ref-implement)",
      "Skill(ref-memory-management)",
      "Skill(ref-pr-check)",
      "Skill(ref-pr-workflow)",
      "Skill(ref-qa)",
      "Skill(ref-ready)",
      "Skill(ref-security)",
      "Skill(ref-unit-test)",
      "Skill(ref-wiggum-loop)",
      "Skill(ref-write-instructions)",
      "Skill(wiggum-loop)",
      "Skill(roadmap-debate)",
      "Skill(worktree)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(gh api /repos/*/issues/*:*)",
      "Bash(gh api repos/*/issues/*:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(.claude/skills/ref-pr-workflow/scripts/run-ci-watch.sh:*)",
      "Bash(gh search:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsx:*)",
      "Bash(npx vite:*)",
      "Bash(npx vitest:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/approve-workflow-commands.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/restore-skill-state.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/clear-skill-state.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "showClearContextOnPlanAccept": true,
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true
  }
}
