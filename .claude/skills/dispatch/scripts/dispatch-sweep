#!/usr/bin/env bash
# dispatch-sweep — reconcile worktrees once per /dispatch queue-scan tick.
#
# Usage:
#   dispatch-sweep                       — full sweep: cleanup merged + classify
#                                          + emit oldest-orphan adoption directive.
#   dispatch-sweep --cleanup-unknown <p> — destructively remove a single worktree
#                                          (only invoked by SKILL.md after explicit
#                                          user confirmation following a prior
#                                          HALT_UNKNOWN exit).
#
# Default mode behavior, in order:
#   1. Build branch -> PR maps for merged + open PRs from a single pair of gh calls.
#      Network/credential failures degrade to empty maps; the sweep continues.
#   2. Enumerate registered worktrees under <project-root>/worktrees/, excluding
#      the main worktree and detached HEADs.
#   3. For each worktree whose branch is in the merged map and which is in sync
#      (clean tree + zero unpushed commits), remove it and its branch.
#   4. Classify the remaining worktrees as active vs orphaned by walking
#      $DISPATCH_SWEEP_PROC_ROOT (default /proc): any /proc/<pid> with a comm
#      starting with ".claude" whose resolved cwd lives inside a worktree path
#      marks that worktree active.
#   5. Among orphans, separate those eligible for adoption (an open PR OR an
#      inferable issue number ^[0-9]+-) from "unknown" orphans (no PR + no
#      inferable issue number) — the latter halt the sweep with exit 3 and a
#      "cleanup-unknown:<path>" directive on stderr.
#   6. From the eligible orphans pick the OLDEST by HEAD commit time and emit
#      "worktree <N> <branch>" on stdout (the same directive shape dispatch-
#      select-target uses for current-worktree mode); SKILL.md routes that to
#      the existing resume-worktree flow.
#
# Environment overrides for testability:
#   DISPATCH_SWEEP_PROC_ROOT  Root of the /proc walk. Default: /proc.
#   DISPATCH_SWEEP_LOG_FILE   Override log path. Default: <root>/tmp/dispatch-sweep.log.
#   DISPATCH_SWEEP_NOW        Override UTC timestamp source (deterministic tests).
#
# Exit codes:
#   0  normal sweep — may have emitted an adoption directive on stdout, or
#      successfully completed --cleanup-unknown.
#   2  invalid invocation (not in a git repo, bad --cleanup-unknown path).
#   3  halted on an unknown-orphan worktree; stderr carries the directive.
#
# NOT set -e: per-worktree errors should not abort the sweep — bookkeeping
# decisions must keep flowing into the log so the next /dispatch tick can act.
set -uo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# shellcheck source=./lib-worktree-in-sync.sh
source "$SCRIPT_DIR/lib-worktree-in-sync.sh"

# Resolve project root + worktrees root from the git common dir. The parent of
# --git-common-dir is the project root in both classic (.git) and bare (.bare)
# layouts — same pattern used by worktree-create.sh / worktree-remove.sh.
GIT_COMMON_DIR=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) \
  || { echo "ERROR: not in a git repo" >&2; exit 2; }
PROJECT_ROOT=$(dirname "$GIT_COMMON_DIR")
WORKTREES_ROOT="$PROJECT_ROOT/worktrees"

LOG_FILE="${DISPATCH_SWEEP_LOG_FILE:-$PROJECT_ROOT/tmp/dispatch-sweep.log}"
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

log() {
  local ts="${DISPATCH_SWEEP_NOW:-$(date -u +%FT%TZ)}"
  printf '%s [dispatch-sweep] %s\n' "$ts" "$*" >>"$LOG_FILE" 2>/dev/null || true
}

# ---- --cleanup-unknown <path> -----------------------------------------------
# Destructive single-worktree removal. Only ever invoked by SKILL.md after the
# user has confirmed a prior HALT_UNKNOWN directive. Does NOT call worktree_in_sync —
# the whole point is to evict potentially-unmerged work the user has accepted losing.
if [[ "${1:-}" == "--cleanup-unknown" ]]; then
  TARGET="${2:-}"
  if [[ -z "$TARGET" ]]; then
    echo "ERROR: --cleanup-unknown requires a path argument" >&2
    exit 2
  fi
  CANON=$(realpath -m "$TARGET" 2>/dev/null) || CANON="$TARGET"
  if [[ "$(dirname "$CANON")" != "$WORKTREES_ROOT" ]]; then
    echo "ERROR: refusing --cleanup-unknown: '$CANON' is not a direct child of $WORKTREES_ROOT" >&2
    exit 2
  fi
  if [[ "$(basename "$CANON")" == "main" ]]; then
    echo "ERROR: refusing --cleanup-unknown: '$CANON' is main" >&2
    exit 2
  fi

  # Is the target actually registered? Iterate the porcelain list once.
  registered=0
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        wp=$(realpath -m "${line#worktree }" 2>/dev/null) || wp="${line#worktree }"
        [[ "$wp" == "$CANON" ]] && registered=1
        ;;
    esac
  done < <(git worktree list --porcelain 2>/dev/null)

  if [[ "$registered" -eq 0 ]]; then
    log "CLEANUP_UNKNOWN_NOT_REGISTERED: '$CANON'"
    exit 0
  fi

  if git worktree remove --force "$CANON" 2>>"$LOG_FILE"; then
    git worktree prune 2>/dev/null || true
    log "CLEANUP_UNKNOWN: '$CANON'"
  else
    log "CLEANUP_UNKNOWN_REMOVE_FAILED: '$CANON'"
  fi
  exit 0
fi

# Reject any other argument shape — the script only has two modes.
if [[ $# -gt 0 ]]; then
  echo "ERROR: unknown argument(s): $*" >&2
  echo "usage: dispatch-sweep [--cleanup-unknown <path>]" >&2
  exit 2
fi

# ---- Step 1: branch -> PR maps ----------------------------------------------
# One gh call covers both states. Failure (network, sandbox, missing creds)
# collapses to an empty map so the rest of the sweep still runs (classification
# + adoption of issue-number-prefixed orphans still works without PR data).
PRS_JSON=$(gh pr list --state all --json number,headRefName,state --limit 200 2>/dev/null) \
  || PRS_JSON='[]'

declare -A MERGED_BY_BRANCH=()
declare -A OPEN_BY_BRANCH=()
while IFS=$'\t' read -r state br n; do
  [[ -z "$br" ]] && continue
  case "$state" in
    MERGED) MERGED_BY_BRANCH["$br"]="$n" ;;
    OPEN)   OPEN_BY_BRANCH["$br"]="$n" ;;
  esac
done < <(printf '%s' "$PRS_JSON" | jq -r '.[] | [.state, .headRefName, .number] | @tsv' 2>/dev/null)

# ---- Step 2: enumerate registered worktrees ---------------------------------
# git worktree list --porcelain records are blank-line-delimited; each record
# opens with a "worktree <path>" line and (for a branch checkout) carries a
# "branch refs/heads/<name>" line. Detached HEADs omit the branch line — skip
# those entirely (no branch -> no PR lookup, nothing to reason about here).
WT_PATHS=()
WT_BRANCHES=()

current_path=""
current_branch=""
flush_record() {
  if [[ -n "$current_path" && -n "$current_branch" ]]; then
    # Restrict to direct children of $WORKTREES_ROOT/<name>, excluding main.
    # Nested worktrees registered under worktrees/main/.claude/worktrees/...
    # (or any other inner location) are out of scope: this sweep targets the
    # standard worktree-create layout only.
    if [[ "$(dirname "$current_path")" == "$WORKTREES_ROOT" \
       && "$(basename "$current_path")" != "main" ]]; then
      WT_PATHS+=("$current_path")
      WT_BRANCHES+=("$current_branch")
    fi
  fi
  current_path=""
  current_branch=""
}

while IFS= read -r line; do
  if [[ -z "$line" ]]; then
    flush_record
  elif [[ "$line" == worktree\ * ]]; then
    current_path="${line#worktree }"
  elif [[ "$line" == branch\ * ]]; then
    br="${line#branch }"
    current_branch="${br#refs/heads/}"
  fi
done < <(git worktree list --porcelain 2>/dev/null)
flush_record

# ---- Step 3: merged cleanup pass --------------------------------------------
# For each worktree whose branch was squash-merged (per gh pr list), if it is
# in sync remove the worktree + delete the local branch. Not-in-sync merged
# worktrees stay on the surviving list with a SKIP log line so the user can
# investigate; they're explicitly NOT auto-adoption candidates (the unpushed
# work may belong to a live session whose comm we missed).
SURVIVING_PATHS=()
SURVIVING_BRANCHES=()

i=0
while [[ $i -lt ${#WT_PATHS[@]} ]]; do
  wt_path="${WT_PATHS[$i]}"
  wt_branch="${WT_BRANCHES[$i]}"
  i=$((i + 1))

  pr_num="${MERGED_BY_BRANCH[$wt_branch]:-}"
  if [[ -z "$pr_num" ]]; then
    SURVIVING_PATHS+=("$wt_path")
    SURVIVING_BRANCHES+=("$wt_branch")
    continue
  fi

  # Branch is merged. Check in-sync; the helper logs its own KEEP/ERROR reason.
  if worktree_in_sync "$wt_path" "$LOG_FILE" "dispatch-sweep"; then
    if git worktree remove "$wt_path" 2>>"$LOG_FILE"; then
      git worktree prune 2>/dev/null || true
      if ! git branch -D "$wt_branch" >>"$LOG_FILE" 2>&1; then
        log "BRANCH_DELETE_FAILED: branch=$wt_branch (worktree removed; branch retained)"
      fi
      log "REMOVE_MERGED: '$wt_path' branch=$wt_branch pr=#$pr_num"
    else
      log "SKIP_WORKTREE_REMOVE_FAILED: '$wt_path' branch=$wt_branch"
      SURVIVING_PATHS+=("$wt_path")
      SURVIVING_BRANCHES+=("$wt_branch")
    fi
  else
    log "SKIP_MERGED_NOT_IN_SYNC: '$wt_path' branch=$wt_branch"
    SURVIVING_PATHS+=("$wt_path")
    SURVIVING_BRANCHES+=("$wt_branch")
  fi
done

# ---- Step 4: classify remaining worktrees as active vs orphaned -------------
# Walk $DISPATCH_SWEEP_PROC_ROOT. A worktree is active when at least one PID's
# comm starts with ".claude" (e.g. ".claude-unwrapp" on NixOS — the comm field
# is already a basename so a prefix test is enough) AND its resolved cwd lies
# inside that worktree's path. /proc may yield transient or unreadable PIDs;
# treat any read failure as "no signal" rather than aborting.
PROC_ROOT="${DISPATCH_SWEEP_PROC_ROOT:-/proc}"

# Initialise the active-pid map for every surviving worktree to empty.
declare -A ACTIVE_PID=()
for wt_path in "${SURVIVING_PATHS[@]}"; do
  ACTIVE_PID["$wt_path"]=""
done

# Precompute "path/" forms for cheap case-glob containment checks.
if [[ -d "$PROC_ROOT" ]]; then
  for entry in "$PROC_ROOT"/*; do
    pid="${entry##*/}"
    [[ "$pid" =~ ^[0-9]+$ ]] || continue

    comm_file="$entry/comm"
    [[ -r "$comm_file" ]] || continue
    comm=""
    IFS= read -r comm <"$comm_file" 2>/dev/null || comm=""
    [[ "$comm" == .claude* ]] || continue

    # cwd is a symlink; readlink follows it, realpath -e canonicalises.
    cwd_link="$entry/cwd"
    cwd=$(readlink -f "$cwd_link" 2>/dev/null) || cwd=""
    [[ -n "$cwd" ]] || continue

    for wt_path in "${SURVIVING_PATHS[@]}"; do
      case "$cwd/" in
        "$wt_path/"*)
          # Record the first PID we see for this worktree; later overlapping
          # claudes don't change the classification.
          if [[ -z "${ACTIVE_PID[$wt_path]:-}" ]]; then
            ACTIVE_PID["$wt_path"]="$pid"
          fi
          break
          ;;
      esac
    done
  done
else
  log "PROC_ROOT_MISSING: '$PROC_ROOT' is not a directory — all surviving worktrees will classify as orphaned"
fi

# Now log ACTIVE / ORPHANED per surviving worktree and collect the orphans.
ORPHAN_PATHS=()
ORPHAN_BRANCHES=()
i=0
while [[ $i -lt ${#SURVIVING_PATHS[@]} ]]; do
  wt_path="${SURVIVING_PATHS[$i]}"
  wt_branch="${SURVIVING_BRANCHES[$i]}"
  i=$((i + 1))

  pid="${ACTIVE_PID[$wt_path]:-}"
  if [[ -n "$pid" ]]; then
    log "ACTIVE: '$wt_path' branch=$wt_branch pid=$pid"
  else
    log "ORPHANED: '$wt_path' branch=$wt_branch"
    ORPHAN_PATHS+=("$wt_path")
    ORPHAN_BRANCHES+=("$wt_branch")
  fi
done

# ---- Step 5: classify orphans + halt on unknown -----------------------------
# Eligible for adoption: open PR for this branch OR the branch matches ^[0-9]+-.
# Unknown (no PR + no issue-number prefix) halts the sweep with exit 3 —
# SKILL.md surfaces a confirmation prompt before re-invoking --cleanup-unknown.
CAND_PATHS=()
CAND_BRANCHES=()
CAND_ISSUES=()

i=0
while [[ $i -lt ${#ORPHAN_PATHS[@]} ]]; do
  wt_path="${ORPHAN_PATHS[$i]}"
  wt_branch="${ORPHAN_BRANCHES[$i]}"
  i=$((i + 1))

  # Infer issue number from the branch name. Anchored on [1-9] to match
  # worktree-create.sh — a "0-foo" branch is not a valid issue worktree.
  issue_num=""
  if [[ "$wt_branch" =~ ^([1-9][0-9]*)- ]]; then
    issue_num="${BASH_REMATCH[1]}"
  fi

  open_pr="${OPEN_BY_BRANCH[$wt_branch]:-}"

  if [[ -z "$open_pr" && -z "$issue_num" ]]; then
    log "HALT_UNKNOWN: '$wt_path' branch=$wt_branch"
    echo "cleanup-unknown:$wt_path" >&2
    exit 3
  fi

  # Open PR but no leading issue number: we can't form the "worktree <N>
  # <branch>" directive. Log and skip — the operator has the log to investigate.
  if [[ -z "$issue_num" ]]; then
    log "SKIP_ORPHAN_NO_ISSUE_NUM: '$wt_path' branch=$wt_branch pr=#$open_pr"
    continue
  fi

  CAND_PATHS+=("$wt_path")
  CAND_BRANCHES+=("$wt_branch")
  CAND_ISSUES+=("$issue_num")
done

# ---- Step 6: oldest-orphan adoption -----------------------------------------
# HEAD commit time (Unix epoch) as the age proxy. On read failure for a
# candidate, log and skip — keeps the script useful even with a broken worktree.
WINNER_IDX=-1
WINNER_CT=""
i=0
while [[ $i -lt ${#CAND_PATHS[@]} ]]; do
  wt_path="${CAND_PATHS[$i]}"
  ct=$(git -C "$wt_path" log -1 --format=%ct HEAD 2>/dev/null) || ct=""
  if ! [[ "$ct" =~ ^[0-9]+$ ]]; then
    log "SKIP_ORPHAN_NO_HEAD_TIME: '$wt_path' branch=${CAND_BRANCHES[$i]}"
    i=$((i + 1))
    continue
  fi
  if [[ -z "$WINNER_CT" || "$ct" -lt "$WINNER_CT" ]]; then
    WINNER_CT="$ct"
    WINNER_IDX=$i
  fi
  i=$((i + 1))
done

if [[ "$WINNER_IDX" -ge 0 ]]; then
  wt_path="${CAND_PATHS[$WINNER_IDX]}"
  wt_branch="${CAND_BRANCHES[$WINNER_IDX]}"
  issue_num="${CAND_ISSUES[$WINNER_IDX]}"
  log "ADOPT_ORPHAN: '$wt_path' branch=$wt_branch issue=$issue_num ct=$WINNER_CT"
  printf 'worktree %s %s\n' "$issue_num" "$wt_branch"
fi

exit 0
