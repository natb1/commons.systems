#!/usr/bin/env bash
set -euo pipefail
ISSUE_NUM="${1:-}"
if [[ -z "$ISSUE_NUM" ]]; then
  ISSUE_NUM=$(git rev-parse --abbrev-ref HEAD | grep -oE '^[1-9][0-9]*' || true)
fi
if [[ -z "$ISSUE_NUM" ]]; then
  echo "error: branch name does not start with an issue number and no argument provided" >&2
  exit 1
fi
PARENT=$(gh api "/repos/{owner}/{repo}/issues/$ISSUE_NUM/parent" --jq '.number' 2>&1) || {
  if [[ "$PARENT" == *"404"* ]] || [[ "$PARENT" == *"No parent issue found"* ]]; then
    exit 0
  fi
  echo "error: failed to fetch parent for issue #$ISSUE_NUM: $PARENT" >&2
  exit 1
}
if [[ ! "$PARENT" =~ ^[0-9]+$ ]]; then
  echo "error: unexpected parent API response: $PARENT" >&2
  exit 1
fi
gh issue view "$PARENT" --json title,body,comments,number,state
