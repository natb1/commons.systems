#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/lib.sh"
ISSUE_NUM=$(resolve_issue_number "${1:-}")
PARENT=$(gh api "/repos/{owner}/{repo}/issues/$ISSUE_NUM/parent" --jq '.number' 2>&1) || {
  if [[ "$PARENT" == *"404"* ]] || [[ "$PARENT" == *"No parent issue found"* ]]; then
    exit 0
  fi
  echo "error: failed to fetch parent for issue #$ISSUE_NUM: $PARENT" >&2
  exit 1
}
if [[ ! "$PARENT" =~ ^[0-9]+$ ]]; then
  echo "error: unexpected parent API response: $PARENT" >&2
  exit 1
fi
SIBLINGS_TSV=$(gh_api_array "/repos/{owner}/{repo}/issues/$PARENT/sub_issues" '.[] | [.number, .state] | @tsv')
while IFS=$'\t' read -r sib state; do
  if [[ -z "$sib" ]]; then continue; fi
  if [[ "$sib" = "$ISSUE_NUM" ]]; then continue; fi
  if [[ "$state" = "open" ]]; then
    gh issue view "$sib" --json title,body,comments,number,state
  else
    gh issue view "$sib" --json title,number,state
  fi
done <<< "$SIBLINGS_TSV"
