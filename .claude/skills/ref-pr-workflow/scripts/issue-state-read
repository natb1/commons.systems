#!/usr/bin/env bash
# Read pr-workflow state from Firestore.
# Usage: issue-state-read <issue-number>
# Exit 0 + JSON on stdout if found; exit 1 on missing/error.
set -euo pipefail

ISSUE_NUM="${1:-}"

if [ -z "$ISSUE_NUM" ] || ! [[ "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: issue number must be a positive integer, got: '${ISSUE_NUM}'" >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec npx tsx "$REPO_ROOT/firestoreutil/bin/run-issue-state-read.ts" "$ISSUE_NUM"
