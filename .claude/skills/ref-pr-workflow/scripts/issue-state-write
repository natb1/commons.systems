#!/usr/bin/env bash
# Write pr-workflow state to Firestore.
# Usage: issue-state-write <issue-number> [json-state]
# If json-state is omitted, reads from stdin.
set -euo pipefail

ISSUE_NUM="${1:-}"
JSON_INPUT="${2:-}"

if [ -z "$ISSUE_NUM" ] || ! [[ "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: issue number must be a positive integer, got: '${ISSUE_NUM}'" >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Resolve the JSON state that will be written — prefer the explicit argument,
# else consume stdin.
if [ -z "$JSON_INPUT" ]; then
  JSON_INPUT="$(cat)"
fi

# Write to Firestore first.
npx tsx "$REPO_ROOT/dispatch/bin/run-issue-state-write.ts" "$ISSUE_NUM" "$JSON_INPUT"

# Mirror state into the dispatcher's local cache if one exists for this
# issue in the current worktree. No-op when the file is absent so callers
# outside a dispatched session (e.g. legacy /pr-workflow) are unaffected.
CACHE_FILE="$REPO_ROOT/tmp/dispatch-${ISSUE_NUM}.json"
if [ -f "$CACHE_FILE" ]; then
  TMP_CACHE=$(mktemp)
  trap 'rm -f "$TMP_CACHE"' EXIT
  jq --argjson state "$JSON_INPUT" '.state = $state' "$CACHE_FILE" > "$TMP_CACHE"
  mv "$TMP_CACHE" "$CACHE_FILE"
  trap - EXIT
fi
