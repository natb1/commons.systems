#!/usr/bin/env bash
# Write pr-workflow state to Firestore.
# Usage: issue-state-write <issue-number> [json-state]
# If json-state is omitted, reads from stdin.
set -euo pipefail

ISSUE_NUM="${1:-}"
JSON_INPUT="${2:-}"

if [ -z "$ISSUE_NUM" ] || ! [[ "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: issue number must be a positive integer, got: '${ISSUE_NUM}'" >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [ -n "$JSON_INPUT" ]; then
  exec npx tsx "$REPO_ROOT/firestoreutil/bin/run-issue-state-write.ts" "$ISSUE_NUM" "$JSON_INPUT"
else
  exec npx tsx "$REPO_ROOT/firestoreutil/bin/run-issue-state-write.ts" "$ISSUE_NUM"
fi
