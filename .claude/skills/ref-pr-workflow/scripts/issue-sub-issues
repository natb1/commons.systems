#!/usr/bin/env bash
set -euo pipefail
ISSUE_NUM="${1:-}"
if [[ -z "$ISSUE_NUM" ]]; then
  ISSUE_NUM=$(git rev-parse --abbrev-ref HEAD | grep -oE '^[1-9][0-9]*' || true)
fi
if [[ -z "$ISSUE_NUM" ]]; then
  echo "error: branch name does not start with an issue number and no argument provided" >&2
  exit 1
fi
SUBS=$(gh api "/repos/{owner}/{repo}/issues/$ISSUE_NUM/sub_issues" --jq '.[].number')
for sub in $SUBS; do
  if [[ ! "$sub" =~ ^[0-9]+$ ]]; then
    echo "error: unexpected sub-issue value: $sub" >&2
    exit 1
  fi
  gh issue view "$sub" --json title,body,comments,number,state
done
