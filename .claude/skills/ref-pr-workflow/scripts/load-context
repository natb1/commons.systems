#!/usr/bin/env bash
# Load all PR workflow context for the current branch's issue.
# Usage: load-context [<issue-number>]
# Derives issue number from branch name if not provided.
# Outputs markdown sections: PR status, primary issue, blockers, sub-issues, parent, siblings, issue state, README.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
source "$SCRIPT_DIR/lib.sh"

ISSUE_NUM=$(resolve_issue_number "${1:-}")

echo "## PR Status"
PR_STDERR_FILE=$(mktemp) || { echo "error: could not create temp file" >&2; exit 1; }
trap 'rm -f "$PR_STDERR_FILE"' EXIT
PR_EXIT=0
PR_OUTPUT=$(gh pr view --json title,body,comments,number,state 2>"$PR_STDERR_FILE") || PR_EXIT=$?
if [[ "$PR_EXIT" -ne 0 ]]; then
  PR_STDERR=$(cat "$PR_STDERR_FILE")
  if echo "$PR_STDERR" | grep -qi "no pull requests found"; then
    PR_OUTPUT="No PR"
  else
    echo "error: failed to fetch PR status (exit $PR_EXIT): $PR_STDERR" >&2
    exit 1
  fi
fi
echo "$PR_OUTPUT"

echo ""
echo "## Primary Issue"
"$SCRIPT_DIR/issue-primary" "$ISSUE_NUM"

echo ""
echo "## Blocking Issues"
"$SCRIPT_DIR/issue-blocking" "$ISSUE_NUM"

echo ""
echo "## Sub-issues"
"$SCRIPT_DIR/issue-sub-issues" "$ISSUE_NUM"

echo ""
echo "## Parent Issue"
"$SCRIPT_DIR/issue-parent" "$ISSUE_NUM"

echo ""
echo "## Sibling Issues"
"$SCRIPT_DIR/issue-siblings" "$ISSUE_NUM"

echo ""
echo "## Issue State"
STATE_OUTPUT=$("$SCRIPT_DIR/issue-state-read" "$ISSUE_NUM" 2>&1) || {
  if [[ "$STATE_OUTPUT" == *"no pr-workflow-state markers"* ]] || [[ "$STATE_OUTPUT" == *"has an empty body"* ]]; then
    STATE_OUTPUT="No state"
  else
    echo "error: issue-state-read failed: $STATE_OUTPUT" >&2
    exit 1
  fi
}
echo "$STATE_OUTPUT"

echo ""
echo "## README"
cat "$REPO_ROOT/README.md"
