#!/usr/bin/env bash
# Write issue context to a markdown file that Claude auto-loads at session start.
# Usage: sync-issue-context <issue-num> [<output-path>]
# Default output path: ./CLAUDE.local.md (relative to CWD).
#
# Sections: primary issue (title + body + comments), blocking issues, sub-issues,
# parent issue (omitted if none), sibling issues (omitted if not a sub-issue).
# Excludes PR status (no PR at worktree creation), issue state (lives in
# tmp/dispatch-<num>.json), and README (auto-loaded by root CLAUDE.md).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

ISSUE_NUM="${1:-}"
if [[ -z "$ISSUE_NUM" || ! "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: usage: sync-issue-context <issue-num> [<output-path>] (got: '${ISSUE_NUM}')" >&2
  exit 1
fi
OUT_PATH="${2:-./CLAUDE.local.md}"

# Render a gh issue view JSON object as a markdown section body: body text
# followed by each comment as a labeled subsection. Arg: $1 = JSON string.
render_issue_body() {
  local json="$1"
  jq -r '.body // ""' <<<"$json"
  local comment_count
  comment_count=$(jq '.comments | length' <<<"$json")
  if [[ "$comment_count" -gt 0 ]]; then
    printf '\n### Comments\n\n'
    jq -r '.comments[] | "**@" + (.author.login // "unknown") + "** (" + (.createdAt // "") + "):\n\n" + (.body // "") + "\n"' <<<"$json"
  fi
}

# Render a related-issue JSON stream (one object per issue) as ### headings
# followed by body text. Body is omitted when absent (e.g., closed siblings
# are summary-only). Input on stdin; output on stdout.
render_related_issues() {
  jq -r '"### #" + (.number|tostring) + " (" + .state + "): " + .title + (if .body then "\n\n" + .body else "" end)'
}

# Fetch primary issue first so we can title the top section.
PRIMARY_JSON=$("$SCRIPT_DIR/issue-primary" "$ISSUE_NUM")
PRIMARY_TITLE=$(jq -r '.title' <<<"$PRIMARY_JSON")

TMP_OUT=$(mktemp) || { echo "error: could not create temp file" >&2; exit 1; }
trap 'rm -f "$TMP_OUT"' EXIT

{
  printf '<!-- AUTO-GENERATED by .claude/skills/ref-pr-workflow/scripts/sync-issue-context. -->\n'
  printf '<!-- Regenerated on worktree create and after requirement changes. Do not edit. -->\n\n'

  printf '# Issue #%s: %s\n\n' "$ISSUE_NUM" "$PRIMARY_TITLE"
  render_issue_body "$PRIMARY_JSON"

  printf '\n## Blocking Issues\n\n'
  BLOCKING=$("$SCRIPT_DIR/issue-blocking" "$ISSUE_NUM")
  if [[ -z "$BLOCKING" ]]; then
    printf '_None._\n'
  else
    render_related_issues <<<"$BLOCKING"
  fi

  printf '\n## Sub-issues\n\n'
  SUBS=$("$SCRIPT_DIR/issue-sub-issues" "$ISSUE_NUM")
  if [[ -z "$SUBS" ]]; then
    printf '_None._\n'
  else
    render_related_issues <<<"$SUBS"
  fi

  PARENT=$("$SCRIPT_DIR/issue-parent" "$ISSUE_NUM")
  if [[ -n "$PARENT" ]]; then
    printf '\n## Parent Issue\n\n'
    render_related_issues <<<"$PARENT"

    printf '\n## Sibling Issues\n\n'
    SIBS=$("$SCRIPT_DIR/issue-siblings" "$ISSUE_NUM")
    if [[ -z "$SIBS" ]]; then
      printf '_None._\n'
    else
      render_related_issues <<<"$SIBS"
    fi
  fi
} > "$TMP_OUT"

mv "$TMP_OUT" "$OUT_PATH"
trap - EXIT
echo "[sync-issue-context] wrote $OUT_PATH" >&2
