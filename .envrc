use flake
watch_file package-lock.json
if [ ! -d node_modules ] || [ package-lock.json -nt node_modules ]; then
  npm ci
fi
export BUDGET_ETL_PASSWORD="$(pass show budget-etl/main)"
# Warn (but don't block shell entry) on chromium revision drift between
# nix-provisioned playwright-driver and npm @playwright/test. CI gates on
# the same check via .github/workflows/flake-check.yml.
.github/scripts/check-playwright-version-sync.sh || true
