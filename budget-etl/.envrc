# budget-etl-scoped direnv environment.
#
# source_up loads the repo-root .envrc (nix flake devshell, npm ci,
# playwright version check) so this subtree gets the full workspace env.
source_up

# Decryption password for the budget-etl CLI. Scoped here rather than the
# repo-root .envrc so the secret is not exported into every shell and child
# process across the whole repo. The CLI also accepts --keychain (macOS);
# BUDGET_ETL_PASSWORD takes precedence.
export BUDGET_ETL_PASSWORD="$(pass show budget-etl/main)"
