#!/usr/bin/env bash
# Out-of-process dispatcher for Claude Code implementation sessions.
# Usage: dispatch <issue-num>
#
# Pre-flight: validates the issue, resolves or creates the worktree (via the
# shared .claude/hooks/worktree-create.sh), hydrates a local cache at
# tmp/dispatch-<num>.json, and exports DISPATCH_ISSUE_NUM +
# DISPATCH_STATE_FILE. Then spawns `claude /dispatch-implement` in the
# foreground while an `fswatch` subshell monitors the cache file; when the
# phase skill writes `state.phase_signal == "complete"`, the watcher SIGTERMs
# Claude and the dispatcher exits.
set -euo pipefail

# --- sluggify --------------------------------------------------------------
# Lowercase, replace non-alnum with `-`, collapse consecutive `-`, strip
# edges, then truncate so `<issue-num>-<slug>` is at most 32 chars. Strips
# trailing `-` after truncation.
# Args: $1 = title, $2 = issue-num
# Output: branch name to stdout (`<issue-num>-<slug>`)
make_slug() {
  local title="$1" num="$2"
  local slug
  slug=$(printf '%s' "$title" | LC_ALL=C tr '[:upper:]' '[:lower:]')
  slug=$(printf '%s' "$slug" | LC_ALL=C sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')
  local max_slug=$((32 - ${#num} - 1))
  if [ "${#slug}" -gt "$max_slug" ]; then
    slug="${slug:0:$max_slug}"
    slug="${slug%%-}"
    while [[ "$slug" == *- ]]; do slug="${slug%-}"; done
  fi
  printf '%s-%s\n' "$num" "$slug"
}

# --- main -------------------------------------------------------------------
main() {
  local ISSUE_NUM="${1:-}"
  if [[ -z "$ISSUE_NUM" || ! "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
    echo "error: usage: dispatch <issue-num> (got: '${ISSUE_NUM}')" >&2
    exit 1
  fi

  local DISPATCH_ROOT
  DISPATCH_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  local REPO_ROOT
  REPO_ROOT="$(git -C "$DISPATCH_ROOT" rev-parse --show-toplevel)"
  local GIT_COMMON_DIR
  GIT_COMMON_DIR="$(git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir)"
  local PROJECT_ROOT
  PROJECT_ROOT="$(dirname "$GIT_COMMON_DIR")"

  # Validate issue is open.
  local ISSUE_STATE
  ISSUE_STATE=$(gh issue view "$ISSUE_NUM" --json state --jq '.state') || {
    echo "error: gh issue view $ISSUE_NUM failed" >&2
    exit 1
  }
  if [[ "$ISSUE_STATE" != "OPEN" ]]; then
    echo "error: issue #$ISSUE_NUM is $ISSUE_STATE, not OPEN" >&2
    exit 1
  fi

  # Compute target branch from title.
  local TITLE BRANCH
  TITLE=$(gh issue view "$ISSUE_NUM" --json title --jq '.title')
  BRANCH=$(make_slug "$TITLE" "$ISSUE_NUM")
  local WORKTREE_PATH="$PROJECT_ROOT/worktrees/$BRANCH"

  # Resolve or create worktree.
  if [[ -e "$WORKTREE_PATH" ]]; then
    local EXISTING_BRANCH
    EXISTING_BRANCH=$(git -C "$WORKTREE_PATH" rev-parse --abbrev-ref HEAD)
    if [[ ! "$EXISTING_BRANCH" =~ ^${ISSUE_NUM}- ]]; then
      echo "error: $WORKTREE_PATH exists but is on branch '$EXISTING_BRANCH' (expected to start with '${ISSUE_NUM}-')" >&2
      exit 1
    fi
    echo "[dispatch] reusing existing worktree $WORKTREE_PATH on branch $EXISTING_BRANCH" >&2
  else
    echo "[dispatch] creating worktree $WORKTREE_PATH (branch $BRANCH)" >&2
    local HOOK="$REPO_ROOT/.claude/hooks/worktree-create.sh"
    if [[ ! -x "$HOOK" ]]; then
      echo "error: worktree-create hook not found or not executable at $HOOK" >&2
      exit 1
    fi
    printf '{"name":"%s"}' "$BRANCH" | "$HOOK" >/dev/null
  fi

  cd "$WORKTREE_PATH"

  # Hydrate local cache.
  "$WORKTREE_PATH/dispatch/bin/sync-issue" "$ISSUE_NUM"

  # Export handoff env for Claude + phase skills.
  export DISPATCH_ISSUE_NUM="$ISSUE_NUM"
  export DISPATCH_STATE_FILE="tmp/dispatch-${ISSUE_NUM}.json"

  # Background watcher: when phase_signal flips to "complete", SIGTERM Claude.
  local CLAUDE_PID=0 WATCHER_PID=0

  start_watcher() {
    (
      fswatch "$DISPATCH_STATE_FILE" | while IFS= read -r _; do
        if jq -e '.state.phase_signal == "complete"' "$DISPATCH_STATE_FILE" >/dev/null 2>&1; then
          [[ "$CLAUDE_PID" -gt 0 ]] && kill -TERM "$CLAUDE_PID" 2>/dev/null || true
          break
        fi
      done
    ) &
    WATCHER_PID=$!
  }

  cleanup() {
    if [[ "$WATCHER_PID" -gt 0 ]] && kill -0 "$WATCHER_PID" 2>/dev/null; then
      kill -TERM "$WATCHER_PID" 2>/dev/null || true
      # Also terminate fswatch, which is the watcher subshell's child.
      pkill -TERM -P "$WATCHER_PID" 2>/dev/null || true
    fi
  }

  on_int() {
    echo "[dispatch] Ctrl-C received — stopping Claude and watcher" >&2
    [[ "$CLAUDE_PID" -gt 0 ]] && kill -TERM "$CLAUDE_PID" 2>/dev/null || true
    cleanup
    exit 130
  }
  trap on_int INT
  trap cleanup EXIT

  start_watcher

  # Spawn Claude in foreground with the phase skill prompt.
  claude "/dispatch-implement #${ISSUE_NUM}" &
  CLAUDE_PID=$!

  # Wait for Claude to exit (no timeout). Tolerate `wait` returning non-zero
  # when the watcher SIGTERMs Claude.
  local CLAUDE_EXIT=0
  wait "$CLAUDE_PID" || CLAUDE_EXIT=$?

  cleanup
  trap - EXIT
  exit "$CLAUDE_EXIT"
}

# Only run main() when executed directly — allows tests to `source` this
# file for access to `make_slug`.
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
