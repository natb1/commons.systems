#!/usr/bin/env bash
# Out-of-process dispatcher for Claude Code implementation sessions.
# Usage: dispatch <issue-num> [<model>]
#
# Validates the issue, computes the branch slug, and launches
# `claude -w <branch> /dispatch-implement` as a child process — Claude
# inherits the controlling TTY directly so the user retains full
# interactive access. A background watcher subshell tracks Claude's PID,
# sleep-polls for phase_signal=complete, and SIGTERMs Claude on match.
# The watcher exits cleanly when kill -0 on Claude's PID fails (Claude
# exited), so no orphaned background processes remain. The dispatcher
# waits for Claude and exits with Claude's status.
set -euo pipefail

# --- sluggify --------------------------------------------------------------
# Lowercase, replace non-alnum with `-`, collapse consecutive `-`, strip
# edges, then truncate so `<issue-num>-<slug>` is at most 32 chars. Strips
# trailing `-` after truncation.
# Args: $1 = title, $2 = issue-num
# Output: branch name to stdout (`<issue-num>-<slug>`)
make_slug() {
  local title="$1" num="$2"
  local slug
  slug=$(printf '%s' "$title" | LC_ALL=C tr '[:upper:]' '[:lower:]')
  slug=$(printf '%s' "$slug" | LC_ALL=C sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')
  local max_slug=$((32 - ${#num} - 1))
  if [ "${#slug}" -gt "$max_slug" ]; then
    slug="${slug:0:$max_slug}"
    while [[ "$slug" == *- ]]; do slug="${slug%-}"; done
  fi
  if [[ -z "$slug" ]]; then
    echo "error: title '$title' produces an empty slug — cannot compute a valid branch name" >&2
    return 1
  fi
  printf '%s-%s\n' "$num" "$slug"
}

# --- diagnose_state ---------------------------------------------------------
# Diagnose the worktree's resume mode against ground truth (open PR, commits
# ahead of origin/main, merged PR). Echoes one of: fresh | audit-and-pr |
# verify | done. For `done`, also echoes the PR number on a second line.
# Args: $1 = branch, $2 = state file path (absolute), $3 = issue num
diagnose_state() {
  local branch="$1" state_file="$2" issue_num="$3"
  local pr_json pr_state pr_number stderr_file rc commits_ahead

  git fetch --quiet origin main || \
    echo "[dispatch] warning: git fetch origin main failed; using local refs" >&2

  stderr_file=$(mktemp)
  set +e
  pr_json=$(gh pr view "$branch" --json number,state 2>"$stderr_file")
  rc=$?
  set -e
  if [[ $rc -ne 0 ]]; then
    if grep -q "no pull requests found" "$stderr_file"; then
      rm -f "$stderr_file"
      commits_ahead=$(git rev-list --count origin/main..HEAD)
      if [[ "$commits_ahead" -eq 0 ]]; then
        echo "fresh"
      else
        echo "audit-and-pr"
      fi
      return 0
    fi
    cat "$stderr_file" >&2
    rm -f "$stderr_file"
    return 1
  fi
  rm -f "$stderr_file"

  pr_state=$(jq -r '.state' <<<"$pr_json")
  pr_number=$(jq -r '.number' <<<"$pr_json")
  if [[ "$pr_state" == "MERGED" ]]; then
    echo "done"
    echo "$pr_number"
  else
    echo "verify"
  fi
  return 0
}

# --- reconcile_phase_signal -------------------------------------------------
# Drop a stale phase_signal so the watcher doesn't fire at launch.
# Args: $1 = scope (local-only | both), $2 = state file path (absolute),
#       $3 = issue number (defaults to $DISPATCH_ISSUE_NUM)
reconcile_phase_signal() {
  local scope="$1" state_file="$2"
  local issue_num="${3:-${DISPATCH_ISSUE_NUM:-}}"
  local tmp_file repo_root read_script write_script remote_json rc

  if [[ "$scope" == "local-only" ]]; then
    if [[ -f "$state_file" ]] && jq -e '.state.phase_signal' "$state_file" >/dev/null 2>&1; then
      tmp_file=$(mktemp)
      jq 'if .state then .state |= del(.phase_signal) else . end' "$state_file" >"$tmp_file"
      mv "$tmp_file" "$state_file"
    fi
    return 0
  fi

  if [[ "$scope" == "both" ]]; then
    repo_root="$(git rev-parse --show-toplevel)"
    read_script="$repo_root/.claude/skills/ref-pr-workflow/scripts/issue-state-read"
    write_script="$repo_root/.claude/skills/ref-pr-workflow/scripts/issue-state-write"
    set +e
    remote_json=$("$read_script" "$issue_num")
    rc=$?
    set -e
    if [[ $rc -ne 0 ]]; then
      echo "[dispatch] warning: issue-state-read exit $rc; reconciling local cache only" >&2
      reconcile_phase_signal local-only "$state_file" "$issue_num"
      return 0
    fi
    if jq -e 'has("phase_signal")' <<<"$remote_json" >/dev/null; then
      remote_json=$(jq 'del(.phase_signal)' <<<"$remote_json")
      "$write_script" "$issue_num" <<<"$remote_json"
    fi
    # issue-state-write mirrors into the cache resolved via its CWD's git
    # toplevel (the project root), not the worktree. Clear the worktree
    # state file directly so the watcher doesn't fire on stale local state.
    reconcile_phase_signal local-only "$state_file" "$issue_num"
    return 0
  fi

  echo "error: reconcile_phase_signal: unknown scope '$scope'" >&2
  return 1
}

# --- prompt_is_tty ----------------------------------------------------------
# Testability hook: returns 0 when stdin is a TTY. Tests override this
# function to force the interactive path without needing a real TTY.
# Default behavior preserved: identical to `[[ -t 0 ]]`.
prompt_is_tty() { [[ -t 0 ]]; }

# --- phase_signal_complete --------------------------------------------------
# Returns 0 iff `state.phase_signal == "complete"` in the JSON file at $1.
# Returns non-zero when the file is absent, unreadable, or the predicate is
# false. This is the protocol-level gate set by `dispatch/bin/phase-complete`
# and consumed by both the watcher (to SIGTERM Claude) and the post-stage
# gating in `should_run_post_stages`.
phase_signal_complete() {
  jq -e '.state.phase_signal == "complete"' "$1" >/dev/null 2>&1
}

# --- should_run_post_stages -------------------------------------------------
# Gate the post-implementation stage sequence: only proceed when the verify
# loop signaled completion AND stdin is a TTY (interactive run).
# Args: $1 = state file path (absolute)
# Returns: 0 if post-stages should run, non-zero otherwise.
should_run_post_stages() {
  local state_file="$1"
  # Testability hook; default behavior preserved (prompt_is_tty wraps [[ -t 0 ]]).
  if ! prompt_is_tty; then
    return 1
  fi
  if [[ ! -f "$state_file" ]]; then
    return 1
  fi
  phase_signal_complete "$state_file"
}

# --- prompt_yes_skip --------------------------------------------------------
# Single-keystroke prompt: Enter = yes (return 0), `s`/`S` = skip (return 1).
# Any other key re-prompts once; on second miss, returns skip. When stdin is
# not a TTY, short-circuits to skip without reading.
# Args: $1 = label (e.g. "Run claude /simplify?")
prompt_yes_skip() {
  local label="$1"
  # Testability hook; default behavior preserved (prompt_is_tty wraps [[ -t 0 ]]).
  if ! prompt_is_tty; then
    return 1
  fi

  # Testability hook: PROMPT_INPUT defaults to /dev/tty; tests set it to a
  # temp file containing scripted input. Open once as FD 3 so sequential reads
  # advance through the file rather than re-opening from position 0. Default
  # behavior preserved (/dev/tty is a character device that always delivers the
  # next keystroke regardless of how many times it is opened).
  local _prompt_input_fd
  exec {_prompt_input_fd}<"${PROMPT_INPUT:-/dev/tty}" || return 1

  local ans=""
  printf '%s' "[dispatch] ${label} [Enter=yes, s=skip]: " >&2
  read -r -n 1 ans <&"$_prompt_input_fd" || { exec {_prompt_input_fd}<&-; return 1; }

  if [[ -z "$ans" ]]; then
    # User pressed Enter alone — read -n 1 returned with no character read.
    exec {_prompt_input_fd}<&-
    return 0
  fi
  printf '\n' >&2
  if [[ "$ans" == "s" || "$ans" == "S" ]]; then
    exec {_prompt_input_fd}<&-
    return 1
  fi

  # Any other key — re-prompt once with stricter semantics.
  ans=""
  printf '%s' "[dispatch] ${label} [Enter=yes, s=skip]: " >&2
  read -r -n 1 ans <&"$_prompt_input_fd" || { exec {_prompt_input_fd}<&-; return 1; }

  exec {_prompt_input_fd}<&-

  if [[ -z "$ans" ]]; then
    return 0
  fi
  printf '\n' >&2
  if [[ "$ans" == "s" || "$ans" == "S" ]]; then
    return 1
  fi
  # Second miss → skip.
  return 1
}

# --- launch_claude_stage ----------------------------------------------------
# Launch a foreground Claude session for a post-implementation stage. The
# user terminates the session (e.g. /exit) to return control. No watcher —
# post-stages are not gated by phase_signal.
# Requires $BRANCH to be set in the caller's scope.
# Args: $1 = slash-command argument (e.g. "/simplify", "/dispatch-qa #123")
launch_claude_stage() {
  local slash="$1"
  claude -w "$BRANCH" "$slash"
}

# --- mark_pr_ready ----------------------------------------------------------
# Resolve the PR number for $1 (branch name) and flip it from draft to
# ready-for-review. Exits non-zero with a descriptive error when the PR
# cannot be found or the gh call fails.
# Args: $1 = branch name
mark_pr_ready() {
  local branch="$1"
  local pr_num=""
  set +e
  pr_num=$(gh pr view "$branch" --json number -q .number 2>/dev/null)
  local rc=$?
  set -e
  if [[ $rc -ne 0 || -z "$pr_num" ]]; then
    echo "error: could not resolve PR number for branch '$branch' — cannot mark ready" >&2
    return 1
  fi
  if ! gh pr ready "$pr_num"; then
    echo "error: gh pr ready $pr_num failed" >&2
    return 1
  fi
  echo "[dispatch] PR #${pr_num} marked ready for review" >&2
  return 0
}

# --- remove_worktree --------------------------------------------------------
# Remove the local worktree at $1 via `git worktree remove` (without --force).
# Force-removal is intentionally not used: by Stage 7 the verify loop has
# succeeded and all work is committed, so any dirty state — or a CWD pointing
# at the worktree being removed — is unexpected and worth surfacing instead of
# silently destroying. Returns non-zero on git failure with the underlying
# error left visible on stderr (git's own message).
# Args: $1 = absolute worktree path
remove_worktree() {
  local path="$1"
  if ! git worktree remove "$path"; then
    echo "error: git worktree remove '$path' failed — inspect the worktree before retrying with --force manually" >&2
    return 1
  fi
  echo "[dispatch] removed worktree $path" >&2
  return 0
}

# --- main -------------------------------------------------------------------
main() {
  local ISSUE_NUM="${1:-}"
  local MODEL="${2:-}"
  if [[ -z "$ISSUE_NUM" || ! "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
    echo "error: usage: dispatch <issue-num> [<model>] (got: '${ISSUE_NUM}')" >&2
    exit 1
  fi

  # Fetch state + title in a single gh call; validate issue is open.
  echo "[dispatch] Fetching issue #${ISSUE_NUM}..." >&2
  local ISSUE_JSON ISSUE_STATE TITLE BRANCH
  ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json state,title) || {
    echo "error: gh issue view $ISSUE_NUM failed" >&2
    exit 1
  }
  ISSUE_STATE=$(jq -r '.state' <<<"$ISSUE_JSON")
  TITLE=$(jq -r '.title' <<<"$ISSUE_JSON")
  echo "[dispatch] state: $ISSUE_STATE" >&2
  if [[ "$ISSUE_STATE" != "OPEN" ]]; then
    echo "error: issue #$ISSUE_NUM is $ISSUE_STATE, not OPEN" >&2
    exit 1
  fi

  # Compute branch and the expected worktree path (convention enforced by
  # .claude/hooks/worktree-create.sh).
  echo "[dispatch] title: $TITLE" >&2
  BRANCH=$(make_slug "$TITLE" "$ISSUE_NUM")
  echo "[dispatch] branch: $BRANCH" >&2

  local GIT_COMMON_DIR PROJECT_ROOT WORKTREE_PATH STATE_FILE
  GIT_COMMON_DIR="$(git rev-parse --path-format=absolute --git-common-dir)" || {
    echo "error: git rev-parse --git-common-dir failed — run dispatch from within the project repo" >&2
    exit 1
  }
  PROJECT_ROOT="$(dirname "$GIT_COMMON_DIR")"
  WORKTREE_PATH="$PROJECT_ROOT/worktrees/$BRANCH"
  STATE_FILE="$WORKTREE_PATH/tmp/dispatch-${ISSUE_NUM}.json"

  # Diagnose worktree state against ground truth (PR existence, commits ahead,
  # PR merge status). Reconcile stale phase_signal in local cache + Firestore
  # when needed, and select a resume instruction to pass to the skill.
  local DIAGNOSIS MODE PR_NUM="" RESUME_INSTRUCTION=""
  DIAGNOSIS=$(diagnose_state "$BRANCH" "$STATE_FILE" "$ISSUE_NUM") || {
    echo "error: diagnose_state failed" >&2
    exit 1
  }
  MODE=$(printf '%s\n' "$DIAGNOSIS" | head -n1)
  PR_NUM=$(printf '%s\n' "$DIAGNOSIS" | sed -n '2p')
  case "$MODE" in
    fresh)
      reconcile_phase_signal local-only "$STATE_FILE" "$ISSUE_NUM"
      ;;
    audit-and-pr)
      reconcile_phase_signal both "$STATE_FILE" "$ISSUE_NUM"
      RESUME_INSTRUCTION="Audit the diff against acceptance criteria; fix any gaps; then proceed to Step 2.5 to create the PR."
      ;;
    verify)
      reconcile_phase_signal both "$STATE_FILE" "$ISSUE_NUM"
      RESUME_INSTRUCTION="An open PR exists for this branch. Skip planning and Step 2; resume at Step 2.5.2 (monitor checks). If all green, run phase-complete."
      ;;
    done)
      echo "[dispatch] issue #${ISSUE_NUM} already shipped via PR #${PR_NUM}" >&2
      exit 0
      ;;
    *)
      echo "error: diagnose_state returned unexpected mode: '$MODE'" >&2
      exit 1
      ;;
  esac

  # Export handoff env for the Claude session and phase skills.
  # STATE_FILE is absolute (used by the watcher here); DISPATCH_STATE_FILE is
  # relative so the skill resolves it from within the worktree's CWD.
  export DISPATCH_ISSUE_NUM="$ISSUE_NUM"
  export DISPATCH_STATE_FILE="tmp/dispatch-${ISSUE_NUM}.json"

  local WATCHER_PID=0
  local CLAUDE_PID=0

  cleanup() {
    if [[ "$WATCHER_PID" -gt 0 ]] && kill -0 "$WATCHER_PID" 2>/dev/null; then
      kill -TERM "$WATCHER_PID" 2>/dev/null || true
      pkill -TERM -P "$WATCHER_PID" 2>/dev/null || true
    fi
  }

  on_int() {
    echo "[dispatch] Ctrl-C received — stopping watcher" >&2
    if [[ "$CLAUDE_PID" -gt 0 ]] && kill -0 "$CLAUDE_PID" 2>/dev/null; then
      kill -TERM "$CLAUDE_PID" 2>/dev/null || true
    fi
    cleanup
    exit 130
  }
  trap on_int INT
  trap cleanup EXIT

  # Build the Claude argv. Claude is launched as a child process so the
  # dispatcher survives to run any post-implementation work after Claude exits.
  local CLAUDE_ARGS=(-w "$BRANCH")
  [[ -n "$MODEL" ]] && CLAUDE_ARGS+=(--model "$MODEL")
  CLAUDE_ARGS+=("/dispatch-implement #${ISSUE_NUM}${RESUME_INSTRUCTION:+

${RESUME_INSTRUCTION}}")
  echo "[dispatch] launching claude -w $BRANCH${MODEL:+ --model $MODEL}..." >&2

  # Launch Claude as a child. It inherits the controlling TTY directly — no
  # stdin redirection, no nohup — so the user retains full interactive access
  # and Ctrl-C is delivered to Claude (the foreground job) by the shell.
  claude "${CLAUDE_ARGS[@]}" &
  CLAUDE_PID=$!

  # Background watcher: polls phase_signal=complete and SIGTERMs the child
  # Claude on match. phase_signal_complete silently returns false when the
  # file doesn't exist yet, so no separate file-existence loop is needed.
  # kill -0 on CLAUDE_PID detects when Claude exits, so the watcher
  # self-terminates cleanly.
  (
    set -euo pipefail
    while kill -0 "$CLAUDE_PID" 2>/dev/null; do
      if phase_signal_complete "$STATE_FILE"; then
        kill -TERM "$CLAUDE_PID" 2>/dev/null || true
        exit 0
      fi
      sleep 1
    done
  ) &
  WATCHER_PID=$!

  # Wait for Claude. set +e around `wait` so a non-zero exit (including the
  # SIGTERM the watcher delivers on phase_signal=complete — the success path)
  # doesn't trip set -e and kill the dispatcher before it can run post-stages.
  local CLAUDE_RC=0
  set +e
  wait "$CLAUDE_PID"
  CLAUDE_RC=$?
  set -e

  # Post-implementation stage gating. The watcher SIGTERMs Claude on
  # phase_signal=complete, which surfaces as exit 143 (128+SIGTERM); a clean
  # /exit after phase-complete is 0. Either way, the authoritative gate is
  # `state.phase_signal == "complete"` in the state file (checked by
  # should_run_post_stages). Other non-zero exits (genuine errors, Ctrl-C
  # before completion) skip the post-stages.
  if [[ "$CLAUDE_RC" -ne 0 && "$CLAUDE_RC" -ne 143 ]]; then
    exit "$CLAUDE_RC"
  fi

  if ! should_run_post_stages "$STATE_FILE"; then
    exit "$CLAUDE_RC"
  fi

  echo "[dispatch] implementation phase complete — entering post-implementation stages" >&2

  # Stage 1: Dispatch QA
  if prompt_yes_skip "Run dispatch-qa?"; then
    launch_claude_stage "/dispatch-qa #${ISSUE_NUM}"
  fi

  # Stage 2: Simplify
  if prompt_yes_skip "Run claude /simplify?"; then
    launch_claude_stage "/simplify"
  fi

  # Stage 3: Review
  if prompt_yes_skip "Run claude /review?"; then
    launch_claude_stage "/review"
  fi

  # Stage 4: Ultrareview
  if prompt_yes_skip "Run claude /ultrareview?"; then
    launch_claude_stage "/ultrareview"
  fi

  # Stage 5: Security review
  if prompt_yes_skip "Run claude /security-review?"; then
    launch_claude_stage "/security-review"
  fi

  # Stage 6: Mark PR ready (not a Claude invocation; one gh call).
  if prompt_yes_skip "Mark PR ready for review?"; then
    if ! mark_pr_ready "$BRANCH"; then
      exit 1
    fi
  fi

  # Stage 7: Remove local worktree (not a Claude invocation; one git call).
  if prompt_yes_skip "Remove local worktree?"; then
    if ! remove_worktree "$WORKTREE_PATH"; then
      exit 1
    fi
  fi

  exit 0
}

# Only run main() when executed directly — allows tests to `source` this
# file for access to `make_slug`.
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
