#!/usr/bin/env bash
# Hydrate the dispatcher's local cache of issue state + context.
# Usage: sync-issue <issue-num>
#
# Writes a JSON file to tmp/dispatch-<issue-num>.json (relative to the
# current working directory, which the dispatcher `cd`s into) with shape:
#
#   { "state":   <firestore state JSON, or null if none>,
#     "context": { "primary": ..., "blockers": [...], "sub_issues": [...],
#                  "parent": ..., "siblings": [...] } }
#
# Phase skills read this file instead of making redundant `gh` calls. Skills
# that edit any of these issues via `gh issue edit/comment` must re-run this
# script to keep the cache in sync.
set -euo pipefail

ISSUE_NUM="${1:-}"
if [[ -z "$ISSUE_NUM" || ! "$ISSUE_NUM" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: usage: sync-issue <issue-num> (got: '${ISSUE_NUM}')" >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPTS="$REPO_ROOT/.claude/skills/ref-pr-workflow/scripts"

mkdir -p tmp
OUT="tmp/dispatch-${ISSUE_NUM}.json"

# Read Firestore state (may be absent — tolerate non-zero exit).
STATE_JSON="null"
if STATE_RAW=$("$SCRIPTS/issue-state-read" "$ISSUE_NUM" 2>/dev/null); then
  if [[ -n "$STATE_RAW" ]] && jq -e . <<<"$STATE_RAW" >/dev/null 2>&1; then
    STATE_JSON="$STATE_RAW"
  fi
fi

# Gather context. Each helper emits one or more JSON objects separated by
# whitespace; `jq -s` collects them into an array. An empty helper output
# yields an empty array.
collect() {
  local cmd="$1"
  local out
  out=$("$SCRIPTS/$cmd" "$ISSUE_NUM" 2>/dev/null || true)
  if [[ -z "$out" ]]; then
    echo "[]"
  else
    jq -s '.' <<<"$out"
  fi
}

primary_raw=$("$SCRIPTS/issue-primary" "$ISSUE_NUM")
primary=$(jq '.' <<<"$primary_raw")

blockers=$(collect issue-blocking)
sub_issues=$(collect issue-sub-issues)
siblings=$(collect issue-siblings)

parent_raw=$("$SCRIPTS/issue-parent" "$ISSUE_NUM" 2>/dev/null || true)
if [[ -z "$parent_raw" ]]; then
  parent="null"
else
  parent=$(jq '.' <<<"$parent_raw")
fi

jq -n \
  --argjson state "$STATE_JSON" \
  --argjson primary "$primary" \
  --argjson blockers "$blockers" \
  --argjson sub_issues "$sub_issues" \
  --argjson parent "$parent" \
  --argjson siblings "$siblings" \
  '{
     state: $state,
     context: {
       primary: $primary,
       blockers: $blockers,
       sub_issues: $sub_issues,
       parent: $parent,
       siblings: $siblings
     }
   }' > "$OUT"

echo "[sync-issue] wrote $OUT" >&2
