{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": [
    {
      "headers": [
        {
          "source": "/blogroll.opml",
          "headers": [
            {
              "key": "Access-Control-Allow-Origin",
              "value": "*"
            },
            {
              "key": "Content-Type",
              "value": "text/x-opml+xml; charset=utf-8"
            }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "public": "landing/dist",
      "target": "landing",
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "budget",
      "public": "budget/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "fellspiral",
      "public": "fellspiral/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/blogroll.opml",
          "headers": [
            {
              "key": "Access-Control-Allow-Origin",
              "value": "*"
            },
            {
              "key": "Content-Type",
              "value": "text/x-opml+xml; charset=utf-8"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/feed-proxy",
          "function": {
            "functionId": "feedProxy"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "print",
      "public": "print/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
