{
  "hosting": [
    {
      "headers": [
        {
          "source": "/blogroll.opml",
          "headers": [
            {
              "key": "Access-Control-Allow-Origin",
              "value": "*"
            },
            {
              "key": "Content-Type",
              "value": "text/x-opml+xml; charset=utf-8"
            }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "public": "landing/dist",
      "target": "landing"
    },
    {
      "target": "budget",
      "public": "budget/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "fellspiral",
      "public": "fellspiral/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/blogroll.opml",
          "headers": [
            { "key": "Access-Control-Allow-Origin", "value": "*" },
            { "key": "Content-Type", "value": "text/x-opml+xml; charset=utf-8" }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
