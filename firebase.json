{
  "hosting": [
    {
      "target": "landing",
      "public": "landing/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/blogroll.opml",
          "headers": [
            { "key": "Access-Control-Allow-Origin", "value": "*" },
            { "key": "Content-Type", "value": "text/x-opml+xml; charset=utf-8" }
          ]
        }
      ]
    },
    {
      "target": "budget",
      "public": "budget/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
