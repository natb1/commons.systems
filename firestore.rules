rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Shared admin check: members of the admin group for an app
    function isAppAdmin(appName, env) {
      return request.auth != null
        && request.auth.token.email in get(/databases/$(database)/documents/$(appName)/$(env)/groups/admin).data.members;
    }

    // Budget group member: verify actual membership via groups collection
    function isBudgetGroupMember(env, groupId, memberEmails) {
      let group = get(/databases/$(database)/documents/budget/$(env)/groups/$(groupId)).data;
      return request.auth != null
        && request.auth.token.email in group.members
        && memberEmails == group.members;
    }

    // Groups are readable only by their members (email-based membership).
    // Uses resource.data directly instead of isGroupMember() because getUserGroups
    // performs a list query (where + getDocs) and Firestore cannot resolve get()
    // calls at query planning time for list queries.
    match /landing/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Published posts are public; unpublished posts require admin group membership
    match /landing/{env}/posts/{postId} {
      allow read: if resource.data.published == true || isAppAdmin("landing", env);
      allow write: if false;
    }

    // Seed transactions are public read-only example data for unauthenticated users
    match /budget/{env}/seed-transactions/{txnId} {
      allow read: if true;
      allow write: if false;
    }

    // Groups are readable only by their members (email-based membership).
    // Uses resource.data directly instead of isGroupMember() because getUserGroups
    // performs a list query (where + getDocs) and Firestore cannot resolve get()
    // calls at query planning time for list queries.
    match /budget/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Transactions are scoped to group members via a denormalized `memberEmails` field.
    // Firestore rules can only read the document being accessed, not join across
    // collections, so membership is checked directly on the transaction document.
    // Updates limited to note, category, reimbursement, budget, and normalization
    // fields (normalizedId, normalizedPrimary, normalizedDescription);
    // reimbursement must be in [0, 100]. Create and delete are explicitly denied.
    match /budget/{env}/transactions/{txnId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.institution == resource.data.institution
        && request.resource.data.account == resource.data.account
        && request.resource.data.description == resource.data.description
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.statementId == resource.data.statementId
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.note is string
        && request.resource.data.category is string
        && (request.resource.data.budget is string || request.resource.data.budget == null)
        && request.resource.data.reimbursement is number
        && request.resource.data.reimbursement >= 0
        && request.resource.data.reimbursement <= 100
        && (!('normalizedId' in request.resource.data) || request.resource.data.normalizedId is string || request.resource.data.normalizedId == null)
        && (!('normalizedPrimary' in request.resource.data) || request.resource.data.normalizedPrimary is bool)
        && (!('normalizedDescription' in request.resource.data) || request.resource.data.normalizedDescription is string || request.resource.data.normalizedDescription == null)
        && request.resource.data.keys().hasOnly(['institution', 'account', 'description', 'amount', 'timestamp', 'statementId', 'groupId', 'memberEmails', 'note', 'category', 'budget', 'reimbursement', 'normalizedId', 'normalizedPrimary', 'normalizedDescription']);
      allow create, delete: if false;
    }

    // Seed budgets are public read-only example data for unauthenticated users
    match /budget/{env}/seed-budgets/{budgetId} {
      allow read: if true;
      allow write: if false;
    }

    // Seed statements are public read-only example data for unauthenticated users
    match /budget/{env}/seed-statements/{statementId} {
      allow read: if true;
      allow write: if false;
    }

    // Statements are scoped to group members via a denormalized `memberEmails` field.
    // Client writes are denied; data is managed via the Admin SDK in ETL.
    match /budget/{env}/statements/{statementId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow write: if false;
    }

    // Seed budget periods are public read-only example data for unauthenticated users
    match /budget/{env}/seed-budget-periods/{periodId} {
      allow read: if true;
      allow write: if false;
    }

    // Budgets are scoped to group members via a denormalized `memberEmails` field.
    // Updates limited to name, allowance (must be non-negative), rollover,
    // and overrides. Create and delete are explicitly denied.
    match /budget/{env}/budgets/{budgetId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.allowance is number
        && request.resource.data.allowance >= 0
        && request.resource.data.rollover in ["none", "debt", "balance"]
        && (!('overrides' in request.resource.data) || request.resource.data.overrides is list)
        && (!('allowancePeriod' in request.resource.data) || request.resource.data.allowancePeriod in ["weekly", "monthly", "quarterly"])
        && request.resource.data.keys().hasOnly(['name', 'allowance', 'allowancePeriod', 'rollover', 'overrides', 'groupId', 'memberEmails']);
      allow create, delete: if false;
    }

    // Budget periods are scoped to group members via a denormalized `memberEmails` field.
    // Client updates may only change total. All other fields must be present but
    // unchanged. Create and delete are explicitly denied.
    match /budget/{env}/budget-periods/{periodId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.budgetId == resource.data.budgetId
        && request.resource.data.periodStart == resource.data.periodStart
        && request.resource.data.periodEnd == resource.data.periodEnd
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.count == resource.data.count
        && request.resource.data.categoryBreakdown == resource.data.categoryBreakdown
        && request.resource.data.total is number
        && request.resource.data.keys().hasOnly(['budgetId', 'periodStart', 'periodEnd', 'total', 'count', 'categoryBreakdown', 'groupId', 'memberEmails']);
      allow create, delete: if false;
    }

    // Seed normalization rules are public read-only example data for unauthenticated users
    match /budget/{env}/seed-normalization-rules/{ruleId} {
      allow read: if true;
      allow write: if false;
    }

    // Validates normalization rule field types and constraints on both create and update.
    function isValidNormalizationRuleData() {
      return request.resource.data.pattern is string
        && request.resource.data.pattern.size() > 0
        && request.resource.data.canonicalDescription is string
        && request.resource.data.canonicalDescription.size() > 0
        && request.resource.data.priority is number
        && (!('patternType' in request.resource.data) || request.resource.data.patternType in ["substring", "regex"])
        && (!('dateWindowDays' in request.resource.data) || (request.resource.data.dateWindowDays is number && request.resource.data.dateWindowDays >= 0))
        && (!('institution' in request.resource.data) || request.resource.data.institution is string || request.resource.data.institution == null)
        && (!('account' in request.resource.data) || request.resource.data.account is string || request.resource.data.account == null)
        && request.resource.data.keys().hasOnly(['pattern', 'patternType', 'canonicalDescription', 'dateWindowDays', 'priority', 'institution', 'account', 'groupId', 'memberEmails']);
    }

    // Normalization rules are scoped to group members via a denormalized `memberEmails` field.
    // CRUD operations require membership. groupId and memberEmails are immutable on update.
    match /budget/{env}/normalization-rules/{ruleId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow create: if isBudgetGroupMember(env, request.resource.data.groupId, request.resource.data.memberEmails)
        && isValidNormalizationRuleData();
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && isValidNormalizationRuleData();
      allow delete: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
    }

    // Seed rules are public read-only example data for unauthenticated users
    match /budget/{env}/seed-rules/{ruleId} {
      allow read: if true;
      allow write: if false;
    }

    // Seed weekly aggregates are public read-only example data for unauthenticated users
    match /budget/{env}/seed-weekly-aggregates/{aggId} {
      allow read: if true;
      allow write: if false;
    }

    // Weekly aggregates are scoped to group members via a denormalized `memberEmails` field.
    // Client writes are denied; data is managed via the ETL pipeline.
    match /budget/{env}/weekly-aggregates/{aggId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow write: if false;
    }

    // Validates rule field types and constraints on both create and update.
    function isValidRuleData() {
      return request.resource.data.type in ["categorization", "budget_assignment"]
        && request.resource.data.pattern is string
        && request.resource.data.target is string
        && request.resource.data.target.size() > 0
        && request.resource.data.priority is number
        && (!('institution' in request.resource.data) || request.resource.data.institution is string || request.resource.data.institution == null)
        && (!('account' in request.resource.data) || request.resource.data.account is string || request.resource.data.account == null)
        && (!('minAmount' in request.resource.data) || request.resource.data.minAmount is number || request.resource.data.minAmount == null)
        && (!('maxAmount' in request.resource.data) || request.resource.data.maxAmount is number || request.resource.data.maxAmount == null)
        && (!('excludeCategory' in request.resource.data) || request.resource.data.excludeCategory is string || request.resource.data.excludeCategory == null)
        && (!('matchCategory' in request.resource.data) || request.resource.data.matchCategory is string || request.resource.data.matchCategory == null)
        && request.resource.data.keys().hasOnly(['type', 'pattern', 'target', 'priority', 'institution', 'account', 'minAmount', 'maxAmount', 'excludeCategory', 'matchCategory', 'groupId', 'memberEmails']);
    }

    // Rules are scoped to group members via a denormalized `memberEmails` field.
    // CRUD operations require membership. groupId and memberEmails are immutable on update.
    match /budget/{env}/rules/{ruleId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow create: if isBudgetGroupMember(env, request.resource.data.groupId, request.resource.data.memberEmails)
        && isValidRuleData();
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && isValidRuleData();
      allow delete: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
    }

    // Groups are readable only by their members (email-based membership).
    // Uses resource.data directly instead of isGroupMember() because getUserGroups
    // performs a list query (where + getDocs) and Firestore cannot resolve get()
    // calls at query planning time for list queries.
    match /fellspiral/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Published posts are public; unpublished posts require fellspiral admin group membership
    match /fellspiral/{env}/posts/{postId} {
      allow read: if resource.data.published == true || isAppAdmin("fellspiral", env);
      allow write: if false;
    }

    // Media items are readable by everyone if public domain, or by group members
    // via denormalized memberEmails array. Client writes are denied; data is managed via the Admin SDK.
    match /print/{env}/media/{mediaId} {
      allow read: if resource.data.publicDomain == true
        || (request.auth != null && request.auth.token.email in resource.data.memberEmails);
      allow write: if false;
    }

    // Groups are readable only by their members (email-based membership).
    // Uses resource.data directly instead of isGroupMember() because getUserGroups
    // performs a list query (where + getDocs) and Firestore cannot resolve get()
    // calls at query planning time for list queries.
    match /print/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Reading positions are private per-user documents keyed by {uid}_{mediaId}.
    // Only the owning user may read or write their own position.
    match /print/{env}/reading-position/{docId} {
      allow read: if request.auth != null
        // resource == null allows getDoc() on a non-existent doc (first visit)
        && (resource == null || request.auth.uid == resource.data.uid);
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.keys().hasAll(['uid', 'mediaId', 'position'])
        && docId == request.auth.uid + "_" + request.resource.data.mediaId;
    }

    // Groups are readable only by their members (email-based membership).
    // Uses resource.data directly instead of isGroupMember() because getUserGroups
    // performs a list query (where + getDocs) and Firestore cannot resolve get()
    // calls at query planning time for list queries.
    match /audio/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Media items are readable by everyone if public domain, or by group members
    // via denormalized memberEmails array. Client writes are denied; data is managed via the Admin SDK.
    match /audio/{env}/media/{mediaId} {
      allow read: if resource.data.publicDomain == true
        || (request.auth != null && request.auth.token.email in resource.data.memberEmails);
      allow write: if false;
    }

    // SCAFFOLD MARKER: deny-all catch-all. Do not edit or move this comment.
    // InsertFirestoreRules inserts new rule blocks immediately above this line.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
