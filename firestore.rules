rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Landing admin: members of the admin group can read unpublished posts
    function isLandingAdmin(env) {
      return request.auth != null
        && request.auth.token.email in get(/databases/$(database)/documents/landing/$(env)/groups/admin).data.members;
    }

    // Groups are readable only by their members (email-based membership)
    match /landing/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Published posts are public; unpublished posts require admin group membership
    match /landing/{env}/posts/{postId} {
      allow read: if resource.data.published == true || isLandingAdmin(env);
      allow write: if false;
    }

    // Seed transactions are public read-only example data for unauthenticated users
    match /budget/{env}/seed-transactions/{txnId} {
      allow read: if true;
      allow write: if false;
    }

    // Groups are readable only by their members (email-based membership)
    match /budget/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Transactions are scoped to group members via a denormalized `memberEmails` field.
    // Firestore rules can only read the document being accessed, not join across
    // collections, so membership is checked directly on the transaction document.
    // Updates limited to note, category, reimbursement, and budget; reimbursement
    // must be in [0, 100]. Create and delete are explicitly denied.
    match /budget/{env}/transactions/{txnId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.institution == resource.data.institution
        && request.resource.data.account == resource.data.account
        && request.resource.data.description == resource.data.description
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.statementId == resource.data.statementId
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.note is string
        && request.resource.data.category is string
        && (request.resource.data.budget is string || request.resource.data.budget == null)
        && request.resource.data.reimbursement is number
        && request.resource.data.reimbursement >= 0
        && request.resource.data.reimbursement <= 100
        && request.resource.data.keys().hasOnly(['institution', 'account', 'description', 'amount', 'timestamp', 'statementId', 'groupId', 'memberEmails', 'note', 'category', 'budget', 'reimbursement']);
      allow create, delete: if false;
    }

    // Seed budgets are public read-only example data for unauthenticated users
    match /budget/{env}/seed-budgets/{budgetId} {
      allow read: if true;
      allow write: if false;
    }

    // Seed budget periods are public read-only example data for unauthenticated users
    match /budget/{env}/seed-budget-periods/{periodId} {
      allow read: if true;
      allow write: if false;
    }

    // Budgets are scoped to group members via a denormalized `memberEmails` field.
    // Updates limited to name, weeklyAllowance (must be non-negative), and rollover;
    // rollover must be one of "none", "debt", "balance". Create and delete are explicitly denied.
    match /budget/{env}/budgets/{budgetId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.weeklyAllowance is number
        && request.resource.data.weeklyAllowance >= 0
        && request.resource.data.rollover in ["none", "debt", "balance"]
        && request.resource.data.keys().hasOnly(['name', 'weeklyAllowance', 'rollover', 'groupId', 'memberEmails']);
      allow create, delete: if false;
    }

    // Budget periods are scoped to group members via a denormalized `memberEmails` field.
    // Client updates may only change total (must be non-negative). All other fields
    // must be present but unchanged. Create and delete are explicitly denied.
    match /budget/{env}/budget-periods/{periodId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.budgetId == resource.data.budgetId
        && request.resource.data.periodStart == resource.data.periodStart
        && request.resource.data.periodEnd == resource.data.periodEnd
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.count == resource.data.count
        && request.resource.data.categoryBreakdown == resource.data.categoryBreakdown
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.keys().hasOnly(['budgetId', 'periodStart', 'periodEnd', 'total', 'count', 'categoryBreakdown', 'groupId', 'memberEmails']);
      allow create, delete: if false;
    }

    // Seed rules are public read-only example data for unauthenticated users
    match /budget/{env}/seed-rules/{ruleId} {
      allow read: if true;
      allow write: if false;
    }

    // Rules are scoped to group members via a denormalized `memberEmails` field.
    // CRUD operations require membership. groupId and memberEmails are immutable on update.
    match /budget/{env}/rules/{ruleId} {
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
      allow create: if request.auth != null
        && request.auth.token.email in request.resource.data.memberEmails
        && request.resource.data.type in ["categorization", "budget_assignment"]
        && request.resource.data.pattern is string
        && request.resource.data.pattern.size() > 0
        && request.resource.data.target is string
        && request.resource.data.target.size() > 0
        && request.resource.data.priority is number
        && (!('institution' in request.resource.data) || request.resource.data.institution is string)
        && (!('account' in request.resource.data) || request.resource.data.account is string)
        && request.resource.data.keys().hasOnly(['type', 'pattern', 'target', 'priority', 'institution', 'account', 'groupId', 'memberEmails']);
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.memberEmails == resource.data.memberEmails
        && request.resource.data.type in ["categorization", "budget_assignment"]
        && request.resource.data.pattern is string
        && request.resource.data.pattern.size() > 0
        && request.resource.data.target is string
        && request.resource.data.target.size() > 0
        && request.resource.data.priority is number
        && (!('institution' in request.resource.data) || request.resource.data.institution is string)
        && (!('account' in request.resource.data) || request.resource.data.account is string)
        && request.resource.data.keys().hasOnly(['type', 'pattern', 'target', 'priority', 'institution', 'account', 'groupId', 'memberEmails']);
      allow delete: if request.auth != null
        && request.auth.token.email in resource.data.memberEmails;
    }

    // Fellspiral admin: members of the admin group can read unpublished posts
    function isFellspiralAdmin(env) {
      return request.auth != null
        && request.auth.token.email in get(/databases/$(database)/documents/fellspiral/$(env)/groups/admin).data.members;
    }

    // Groups are readable only by their members (email-based membership)
    match /fellspiral/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // Published posts are public; unpublished posts require fellspiral admin group membership
    match /fellspiral/{env}/posts/{postId} {
      allow read: if resource.data.published == true || isFellspiralAdmin(env);
      allow write: if false;
    }

    // Media items are readable by everyone if public domain, or by group members
    // via denormalized memberEmails array. Client writes are denied; data is managed via the Admin SDK.
    match /print/{env}/media/{mediaId} {
      allow read: if resource.data.publicDomain == true
        || (request.auth != null && request.auth.token.email in resource.data.memberEmails);
      allow write: if false;
    }

    // Groups are readable only by their members (email-based membership)
    match /print/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.token.email in resource.data.members;
      allow write: if false;
    }

    // SCAFFOLD MARKER: deny-all catch-all. Do not edit or move this comment.
    // InsertFirestoreRules inserts new rule blocks immediately above this line.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
