rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Published posts are public; unpublished posts require authentication
    match /landing/{env}/posts/{postId} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if false;
    }

    match /budget/{env}/seed-transactions/{txnId} {
      allow read: if true;
      allow write: if false;
    }

    match /budget/{env}/groups/{groupId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow write: if false;
    }

    match /budget/{env}/transactions/{txnId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/budget/$(env)/groups/$(resource.data.groupId)).data.members;
      allow update: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/budget/$(env)/groups/$(resource.data.groupId)).data.members
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['note', 'category', 'reimbursement', 'budget']);
      allow create, delete: if false;
    }

    // Deny everything else by default (scaffolding uses this line as an insertion marker)
    // DO NOT EDIT the line above — the scaffolding's InsertFirestoreRules depends on it.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
