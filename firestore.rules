rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Messages are publicly readable; notes require authentication (see below)
    match /landing/{env}/messages/{messageId} {
      allow read: if true;
      allow write: if false;
    }

    // Notes require authentication
    match /landing/{env}/notes/{noteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Published posts are public; unpublished posts require authentication
    match /landing/{env}/posts/{postId} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
