name: {{.Title}} — Unit Tests & Lint

on:
  push:
    branches-ignore:
      - main
    paths:
      - "{{.AppName}}/**"
      - "authutil/**"
      - "firestoreutil/**"
      - "firebaseutil/**"
      - "style/**"
      - ".claude/skills/ref-pr-workflow/scripts/**"

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4
      - uses: actions/setup-node@v4
        with:
          node-version: "22"
      - name: Run unit tests
        run: .claude/skills/ref-pr-workflow/scripts/run-unit-tests.sh {{.AppName}}
      - name: Run lint
        run: .claude/skills/ref-pr-workflow/scripts/run-lint.sh {{.AppName}}
